#!/bin/bash

# Pre-commit hook: Run Rails tests before allowing commit
# If tests fail, the commit is aborted

echo "🧪 Running tests before commit..."

# Navigate to the Rails app directory
cd "$(git rev-parse --show-toplevel)/photos_store_app"

# Run Minitest
echo "Running Minitest..."
bin/rails test

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Minitest failed! Commit aborted."
  exit 1
fi

# Run RSpec
echo ""
echo "Running RSpec..."
bundle exec rspec

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ RSpec failed! Commit aborted."
  exit 1
fi

echo ""
echo "✅ All tests passed! Proceeding with commit."
exit 0
